{
  "name": "procourts-club",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run optimize-images && vite build && node scripts/optimize-dist-assets.mjs",
    "build:staging": "npm run optimize-images && vite build --mode staging && node scripts/optimize-dist-assets.mjs",
    "build:production": "npm run optimize-images && vite build --mode production && node scripts/optimize-dist-assets.mjs",
    "preview": "vite preview",
    "preview:staging": "vite preview --mode staging",
    "deploy": "vite build && gh-pages -d dist",
    "optimize-images": "node scripts/optimize-images.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.39.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "react-svg-pan-zoom": "^3.13.1",
    "styled-components": "^6.3.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "gh-pages": "^6.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
